{
  "framework": "nextjs",
  "buildCommand": "next build",
  "devCommand": "next dev",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "env": {
    "NEXT_PUBLIC_SUPABASE_URL": "@inkverse-supabase-url",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY": "@inkverse-supabase-anon-key",
    "SUPABASE_SERVICE_ROLE_KEY": "@inkverse-service-role-key",
    "NEXT_PUBLIC_APP_URL": "@inkverse-app-url"
  },
  "regions": ["iad1"],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/comic/(.*)/chapter/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex" }
      ]
    }
  ]
}
